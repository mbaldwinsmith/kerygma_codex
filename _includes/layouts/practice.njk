---
layout: base
---
<article class="practice">

  {# ── Header ─────────────────────────────────────────────────────────────── #}
  <div class="page-header">
    <div class="container--wide">

      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="{{ '/' | url }}">Home</a></li>
          <li><a href="{{ '/practices/' | url }}">Practices</a></li>
          <li aria-current="page">{{ title }}</li>
        </ol>
      </nav>

      <div class="grid-two practice-header__grid">
        <div>
          <span class="tag tag--practices">Practice</span>
          <h1>{{ title }}</h1>
        </div>
        <div class="practice-header__illustration" aria-hidden="true">
          <img
            src="{{ '/assets/images/illustrations/sections/practices.svg' | url }}"
            alt=""
            class="float"
            width="480"
            height="320"
          >
        </div>
      </div>

    </div>
  </div>

  {# ── Body ────────────────────────────────────────────────────────────────── #}
  <div class="section--sm">
    <div class="container--wide">
      <div class="content-with-sidebar">

        <div class="prose reveal">
          {{ content | safe }}
        </div>

        {# TOC container — populated by ui.js (Phase 9) #}
        <aside class="sidebar" aria-label="Page contents">
          <div class="toc">
            <p class="toc__heading">Contents</p>
            <ul class="toc__list" id="toc-list"></ul>
          </div>
        </aside>

      </div>

      {# ── Prev / Next ───────────────────────────────────────────────────── #}
      {% set prevItem = collections.practices | getPreviousCollectionItem(page) %}
      {% set nextItem = collections.practices | getNextCollectionItem(page) %}
      {% if prevItem or nextItem %}
        <nav class="page-nav" aria-label="Browse practices">
          {% if prevItem %}
            <div class="page-nav__link page-nav__link--prev">
              <span class="page-nav__label">← Previous</span>
              <a href="{{ prevItem.url | url }}">{{ prevItem.data.title }}</a>
            </div>
          {% endif %}
          {% if nextItem %}
            <div class="page-nav__link page-nav__link--next">
              <span class="page-nav__label">Next →</span>
              <a href="{{ nextItem.url | url }}">{{ nextItem.data.title }}</a>
            </div>
          {% endif %}
        </nav>
      {% endif %}

    </div>
  </div>

</article>
